  "scroll_to_comments": {
    "description": "Scroll the page down by one page-height. Tiny recipe \u2014 agent should re-fire it (and check vision between fires) until the comments section is visible. Bypasses the loop-detector's bare-scroll abort by using Page_Down hotkey.",
    "triggers": [
      "scroll\\s+(?:down\\s+)?to(?:wards?)?\\s+(?:the\\s+)?comments?(?:\\s+section)?",
