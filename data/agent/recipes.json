{
  "_meta": {
    "description": "Deterministic action recipes for the Guaardvark agent. These skip the see-think-act loop entirely.",
    "format": "Each recipe has trigger patterns (regex) and a sequence of steps. Steps may be hotkey/type/click for actions, or wait_until_settled/wait_until_visible for vision-gated waiting. Recipes can also declare a top-level success_proof \u2014 a vision-readable description that must be visible before the recipe is reported successful. Legacy `wait` steps still work but log a deprecation warning.",
    "timing": "wait values are in seconds"
  },
  "open_firefox": {
    "description": "Open Firefox by clicking its desktop icon (the column down the left edge of the XFCE desktop)",
    "triggers": [
      "^(?:open|start|launch)\\s+(?:the\\s+)?(?:firefox|chrome|chromium|browser)\\s*$",
      "^(?:open|start|launch)\\s+(?:the\\s+)?(?:firefox|chrome|chromium|browser)\\s+(?:browser)?\\s*$"
    ],
    "preconditions": [
      "firefox_not_running"
    ],
    "steps": [
      {
        "action": "click",
        "target_description": "Firefox icon (flame) on the desktop",
        "_comment": "Vision-driven \u2014 servo finds the flame icon among the desktop icons"
      },
      {
        "action": "wait_until_visible",
        "target_description": "Firefox browser window with URL bar",
        "timeout_s": 8.0
      }
    ]
  },
  "open_firefox_and_navigate": {
    "description": "Open Firefox from the desktop and navigate to a URL",
    "triggers": [
      "^(?:open|start|launch)\\s+(?:the\\s+)?(?:firefox|chrome|chromium|browser)\\s+(?:and\\s+)?(?:go|navigate)\\s+(?:to\\s+)?(?:https?://)?([\\w.-]+(?::[0-9]+)?(?:/\\S*?)?)(?:\\s+please)?\\s*$",
      "^(?:open|start|launch)\\s+(?:the\\s+)?(?:firefox|chrome|chromium|browser)\\s+(?:to|at|on)\\s+(?:https?://)?([\\w.-]+(?::[0-9]+)?(?:/\\S*?)?)(?:\\s+please)?\\s*$"
    ],
    "preconditions": [
      "firefox_not_running"
    ],
    "steps": [
      {
        "action": "click",
        "target_description": "Firefox icon (flame) on the desktop",
        "_comment": "Vision-driven \u2014 servo finds the flame icon among the desktop icons"
      },
      {
        "action": "wait_until_visible",
        "target_description": "Firefox browser window with URL bar",
        "timeout_s": 8.0
      },
      {
        "action": "hotkey",
        "keys": [
          "ctrl",
          "l"
        ]
      },
      {
        "action": "wait_until_settled",
        "timeout_s": 1.0,
        "stable_for_ms": 200
      },
      {
        "action": "hotkey",
        "keys": [
          "ctrl",
          "a"
        ]
      },
      {
        "action": "type",
        "text": "{1}"
      },
      {
        "action": "hotkey",
        "keys": [
          "Return"
        ]
      },
      {
        "action": "wait_until_settled",
        "timeout_s": 5.0,
        "stable_for_ms": 300
      }
    ]
  },
  "navigate_url": {
    "description": "Navigate to a domain-shaped URL in the current tab. Hostname must contain a dot OR port \u2014 bare words like 'open settings' or 'go to youtube' route to their dedicated recipes instead.",
    "triggers": [
      "^(?:navigate|go)\\s+to\\s+(?:https?://)?(\\w[\\w.-]*\\.[\\w.-]+(?::[0-9]+)?(?:/\\S*?)?)\\s*$",
      "^(?:navigate|go)\\s+to\\s+(?:https?://)?([\\w.-]+:[0-9]+(?:/\\S*?)?)\\s*$",
      "^open\\s+(?:https?://)?(\\w[\\w.-]*\\.[\\w.-]+(?::[0-9]+)?(?:/\\S*?)?)\\s*$",
      "^open\\s+(?:https?://)?([\\w.-]+:[0-9]+(?:/\\S*?)?)\\s*$",
      "^visit\\s+(?:https?://)?(\\w[\\w.-]*\\.[\\w.-]+(?::[0-9]+)?(?:/\\S*?)?)\\s*$",
      "^visit\\s+(?:https?://)?([\\w.-]+:[0-9]+(?:/\\S*?)?)\\s*$"
    ],
    "steps": [
      {
        "action": "hotkey",
        "keys": [
          "Escape"
        ]
      },
      {
        "action": "wait_until_settled",
        "timeout_s": 1.0,
        "stable_for_ms": 150
      },
      {
        "action": "hotkey",
        "keys": [
          "ctrl",
          "l"
        ]
      },
      {
        "action": "wait_until_visible",
        "target_description": "URL address bar with text selected or empty and ready for typing",
        "timeout_s": 4.0
      },
      {
        "action": "hotkey",
        "keys": [
          "ctrl",
          "a"
        ]
      },
      {
        "action": "wait_until_settled",
        "timeout_s": 1.0,
        "stable_for_ms": 150
      },
      {
        "action": "type",
        "text": "http://{1}"
      },
      {
        "action": "wait_until_settled",
        "timeout_s": 1.0,
        "stable_for_ms": 150
      },
      {
        "action": "hotkey",
        "keys": [
          "Delete"
        ]
      },
      {
        "action": "wait_until_settled",
        "timeout_s": 0.8,
        "stable_for_ms": 150
      },
      {
        "action": "hotkey",
        "keys": [
          "Return"
        ]
      }
    ],
    "success_proof": "browser address bar showing a loaded page (not a blank tab or error)",
    "success_proof_timeout_s": 12.0
  },
  "new_tab": {
