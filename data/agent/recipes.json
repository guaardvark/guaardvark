{
  "_meta": {
    "description": "Deterministic action recipes for the Guaardvark agent. Each recipe matches a user task via case-insensitive regex and executes a fixed sequence of steps, skipping the see-think-act LLM loop entirely.",
    "format": "Each recipe has `triggers` (regex patterns) and `steps`. Steps may be: hotkey, type, click for actions; wait_until_settled or wait_until_visible for vision-gated waits. A recipe with `success_proof` validates completion via a vision check before reporting success; without it, the recipe is terminal (fire-and-trust — servo/keyboard success IS task completion, no fallback to the LLM loop).",
    "design": "Prefer terminal recipes (no success_proof) for atomic actions. Use vision-gated verification only when post-action state confirmation is genuinely required and the model can be relied on to recognize the proof.",
    "timing": "wait values are in seconds. Placeholder {1}, {2}, ... in step text/target fields substitutes regex capture groups.",
    "ordering": "Recipes are evaluated in dict order. More specific recipes (e.g. click_star_icon) must come before generic catch-alls (e.g. navigate_url_generic) so the specific match wins."
  },

  "click_firefox_icon": {
    "description": "Click the desktop Firefox launcher. One click, done. Fire-and-trust: the servo's click success is the task completion signal.",
    "_note": "Triggers cover both 'firefox' phrasings (current icon) AND 'star' phrasings (legacy, from when the icon was temporarily a star for testing). Vision target is now 'Firefox icon' to match what's actually on screen.",
    "triggers": [
      "^(?:please\\s+)?click\\s+(?:on\\s+)?(?:the\\s+)?(?:orange\\s+|red\\s+|big\\s+|little\\s+)?firefox(?:\\s+icon)?(?:\\s+on\\s+(?:the|your)\\s+(?:screen|desktop))?(?:\\s+once)?(?:\\s+please)?\\s*[.!?]?\\s*$",
      "^(?:please\\s+)?(?:open|launch|start)\\s+(?:the\\s+)?firefox(?:\\s+browser)?(?:\\s+icon)?\\s*[.!?]?\\s*$",
      "^(?:please\\s+)?click\\s+(?:on\\s+)?(?:the\\s+)?(?:firefox|browser)\\s+launcher\\s*[.!?]?\\s*$",
      "^(?:please\\s+)?click\\s+(?:on\\s+)?(?:the\\s+)?(?:yellow\\s+|orange\\s+|gold\\s+|big\\s+|little\\s+)?star(?:\\s+icon)?(?:\\s+on\\s+(?:the|your)\\s+(?:screen|desktop))?(?:\\s+once)?(?:\\s+please)?\\s*[.!?]?\\s*$",
      "^(?:please\\s+)?tap\\s+(?:on\\s+)?(?:the\\s+)?(?:yellow\\s+|orange\\s+|gold\\s+)?star(?:\\s+icon)?(?:\\s+on\\s+(?:the|your)\\s+(?:screen|desktop))?(?:\\s+please)?\\s*[.!?]?\\s*$"
    ],
    "steps": [
      {"action": "click", "target_description": "the Firefox icon on the desktop"}
    ]
  },

  "press_enter": {
    "description": "Press the Enter / Return key.",
    "triggers": [
      "^(?:please\\s+)?(?:press|hit|tap|push)\\s+(?:the\\s+)?(?:enter|return)(?:\\s+key)?\\s*[.!?]?\\s*$",
      "^(?:please\\s+)?(?:submit|confirm)\\s*[.!?]?\\s*$"
    ],
    "steps": [
      {"action": "hotkey", "keys": ["Return"]}
    ]
  },

