# Node
node_modules/

# Application data (generated at runtime)
data/uploads/
data/outputs/
data/cache/
data/database/
data/models/
data/context/

# Plugin runtime artifacts (generated per-machine, never sync)
plugins/*/outputs/
plugins/*/output/
