# Plugin runtime artifacts (generated per-machine, never sync)
plugins/*/outputs/
plugins/*/output/
plugins/*/cache/
plugins/*/tmp/
plugins/*/.cache/
plugins/*/__pycache__/
data/plugin_state.json
data/social_outreach/
