#!/bin/bash

# LLAMAX System Manager - Central Management for LLAMAX Environments
# Location: ~/LLAMAX6/scripts/system-manager/system-manager

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Resolve real path of the script to handle symlinks
REAL_SCRIPT_PATH=$(readlink -f "${BASH_SOURCE[0]}")
MANAGER_DIR="$( cd "$( dirname "$REAL_SCRIPT_PATH" )" && pwd )"
LIB_DIR="$MANAGER_DIR/lib"
PYTHON_CMD="python3"

# Ensure we can import our libs
export PYTHONPATH="$LIB_DIR:$PYTHONPATH"

show_help() {
    echo -e "${BLUE}LLAMAX System Manager${NC}"
    echo "Usage: $0 [COMMAND] [ARGS]"
    echo ""
    echo "Commands:"
    echo "  list               List all registered environments"
    echo "  discover           Scan for new LLAMAX environments"
    echo "  check [path]       Run a health check on an environment"
    echo "  repair             Repair an environment (interactive if no path)"
    echo "  remove             Remove an environment from registry (interactive)"
    echo "  run [path] -- [cmd] Run a command in an environment's context"
    echo "  isolate [path]     Run a command/shell in a Linux namespace (isolated)"
    echo "  status             Overview of system health"
    echo ""
}

select_environment() {
    echo -e "${BLUE}Registered Environments:${NC}"
    local envs=()
    local i=1
    
    # Get environments and store in array
    while IFS='|' read -r path name status; do
        if [ -n "$path" ]; then
            envs+=("$path")
            echo -e "  $i) ${YELLOW}$name${NC} ($path)"
            i=$((i+1))
        fi
    done < <($PYTHON_CMD -c 'from registry import list_environments; envs=list_environments(); [print(k + "|" + v.get("name", "Unknown") + "|" + v.get("status", "?")) for k,v in envs.items()]')

    if [ ${#envs[@]} -eq 0 ]; then
        echo "No environments registered. Run 'discover' first."
        return 1
    fi

    echo -ne "Select an environment (1-${#envs[@]}) or 'q' to quit: "
    read -r choice
    if [[ "$choice" == "q" ]]; then return 1; fi
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#envs[@]} ]; then
        echo "Invalid selection."
        return 1
    fi
    
    SELECTED_PATH="${envs[$((choice-1))]}"
    return 0
}

case "$1" in
    --help|-h|help)
        show_help
        ;;
    list)
        $PYTHON_CMD -c 'from registry import list_environments; envs=list_environments(); [print(k + " | " + v.get("name", "Unknown") + " | " + v.get("status", "?")) for k,v in envs.items()]' | column -t -s "|"
        ;;
    discover)
        echo "Scanning for environments..."
        $PYTHON_CMD "$LIB_DIR/discovery.py"
        ;;
    check)
        TARGET_PATH="${2:-$(pwd)}"
        TARGET_PATH=$(readlink -f "$TARGET_PATH")
        echo -e "Checking health for: ${YELLOW}$TARGET_PATH${NC}"
        RESULT=$($PYTHON_CMD "$LIB_DIR/health_check.py" "$TARGET_PATH")
        
        HEALTHY=$(echo "$RESULT" | python3 -c "import sys, json; print(json.load(sys.stdin).get('healthy', False))")
        
        if [ "$HEALTHY" = "True" ]; then
            echo -e "${GREEN}✓ Environment is healthy.${NC}"
        else
            echo -e "${RED}✗ Environment issues detected:${NC}"
            echo "$RESULT" | python3 -c "import sys, json; r=json.load(sys.stdin); [print(f'  - {k}: {v[1]}') for k,v in r.get('details', {}).items() if not v[0]]"
            echo ""
            echo "Try running: $0 repair $TARGET_PATH"
            exit 1
        fi
        ;;
    repair)
        TARGET_PATH="$2"
        if [ -z "$TARGET_PATH" ]; then
            if ! select_environment; then exit 0; fi
            TARGET_PATH="$SELECTED_PATH"
        fi
        TARGET_PATH=$(readlink -f "$TARGET_PATH")
        echo -e "Repairing environment: ${YELLOW}$TARGET_PATH${NC}"
        
        # Simple repair logic: rebuild venv if it looks broken
        BACKEND_DIR="$TARGET_PATH/backend"
        VENV_DIR="$BACKEND_DIR/venv"
        
        if [ -d "$BACKEND_DIR" ]; then
            echo "Re-installing dependencies..."
            if [ ! -d "$VENV_DIR" ]; then
                python3 -m venv "$VENV_DIR"
            fi
            # Use requirements-base.txt to avoid overwriting smart-installed PyTorch
            if [ -f "$BACKEND_DIR/requirements-base.txt" ]; then
                "$VENV_DIR/bin/pip" install -r "$BACKEND_DIR/requirements-base.txt"
            else
                "$VENV_DIR/bin/pip" install -r "$BACKEND_DIR/requirements.txt"
            fi
            echo -e "${GREEN}✓ Repair complete.${NC}"
        else
            echo -e "${RED}✗ Cannot repair: $BACKEND_DIR not found.${NC}"
            exit 1
        fi
        ;;
    remove)
        if ! select_environment; then exit 0; fi
        echo -ne "Are you sure you want to remove ${YELLOW}$SELECTED_PATH${NC} from registry? (y/N): "
        read -r confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            $PYTHON_CMD -c "from registry import remove_environment; remove_environment('$SELECTED_PATH')"
            echo -e "${GREEN}Removed from registry.${NC}"
        fi
        ;;
    run)
        TARGET_PATH="$2"
        shift 2
        # Remove -- if it exists
        if [ "$1" = "--" ]; then shift; fi
        
        if [ -z "$TARGET_PATH" ] || [ -z "$1" ]; then
            echo "Usage: $0 run [path] -- [cmd]"
            exit 1
        fi
        
        TARGET_PATH=$(readlink -f "$TARGET_PATH")
        export LLAMAX_ROOT="$TARGET_PATH"
        cd "$TARGET_PATH" || exit 1
        
        # Activate venv if it exists for the command
        if [ -f "backend/venv/bin/activate" ]; then
            source "backend/venv/bin/activate"
        fi
        
        exec "$@"
        ;;
    isolate)
        TARGET_PATH="${2:-$(pwd)}"
        shift 2
        # Remove -- if it exists
        if [ "$1" = "--" ]; then shift; fi
        
        TARGET_PATH=$(readlink -f "$TARGET_PATH")
        
        if [ ! -d "$TARGET_PATH" ]; then
            echo -e "${RED}Error: Path '$TARGET_PATH' does not exist.${NC}"
            exit 1
        fi

        echo -e "${BLUE}Entering isolated environment for: ${YELLOW}$TARGET_PATH${NC}"
        
        COMMAND="$@"
        if [ -z "$COMMAND" ]; then COMMAND="/bin/bash"; fi
        
        # Check if we are already root (euid 0)
        if [ "$(id -u)" -eq 0 ]; then
            # Already root (via sudo), use simple unshare
            UNSHARE_CMD="unshare -m -p -f --mount-proc"
        else
            # Not root, try unprivileged user namespace mapping
            UNSHARE_CMD="unshare -r -m -p -f --mount-proc"
            
            # Verify if unprivileged unshare works
            if ! unshare -r true 2>/dev/null; then
                echo -e "${YELLOW}Warning: unprivileged unshare failed. Attempting with sudo...${NC}"
                exec sudo "$REAL_SCRIPT_PATH" isolate "$TARGET_PATH" "$@"
            fi
        fi
        
        exec $UNSHARE_CMD bash -c "
            export LLAMAX_ROOT='$TARGET_PATH'
            cd '$TARGET_PATH' || { echo 'Error: Could not cd to $TARGET_PATH'; exit 1; }
            if [ -f 'backend/venv/bin/activate' ]; then
                source 'backend/venv/bin/activate'
            fi
            echo -e '${GREEN}Namespace PID: \$\$ (Isolated)${NC}'
            echo -e '${BLUE}Current Path: \$(pwd)${NC}'
            $COMMAND
        "
        ;;
    status)
        echo -e "${BLUE}System Manager Status:${NC}"
        $PYTHON_CMD -c 'from registry import list_environments; envs=list_environments(); print("Registered Environments: " + str(len(envs)))'
        $PYTHON_CMD -c 'import os; print("Registry File: " + os.path.expanduser("~/.llamax_registry.json"))'
        ;;
    *)
        show_help
        ;;
esac
